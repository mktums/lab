---
services:
  inpx-web:
    image: "{{ inpx_web_image_name }}:{{ inpx_web_image_tag }}"
    restart: unless-stopped
    command: >-
      /srv/inpx-web
      --data-dir=/data/inpx-web
      --lib-dir=/downloads/{{ inpx_web_lib_dir | basename }}
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:12380/ || exit 1"]
      interval: 60s
      timeout: 5s
      retries: 3
    ports:
      - "{{ inpx_web_port }}:12380"
    volumes:
      - "{{ inpx_web_data_dir }}/inpx-web:/data/inpx-web"
      - "{{ downloads_dir }}:/downloads:ro"
      - /etc/localtime:/etc/localtime:ro
    environment:
      LIB_DOMAIN: "{{ inpx_web_cname }}.{{ lan_domain }}"
    labels:
      traefik.enable: "true"
      traefik.http.routers.inpx-web.rule: "Host(`{{ inpx_web_cname }}.{{ lan_domain }}`)"
      traefik.http.routers.inpx-web.entrypoints: "websecure"
      traefik.http.routers.inpx-web.service: "inpx-web-svc"
      traefik.http.routers.inpx-web.tls: "true"
      traefik.http.routers.inpx-web.tls.certresolver: "step-ca"
      traefik.http.services.inpx-web-svc.loadbalancer.server.port: "12380"

  liberama:
    image: "{{ inpx_web_image_name }}:{{ inpx_web_image_tag }}"
    restart: unless-stopped
    command: /srv/liberama --app-dir=/data/liberama
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:44080/read || exit 1"]
      interval: 60s
      timeout: 5s
      retries: 3
    ports:
      - "{{ inpx_web_liberama_port }}:44080"
    volumes:
      - "{{ inpx_web_data_dir }}/liberama:/data/liberama"
      - /etc/localtime:/etc/localtime:ro
    environment:
      LIB_DOMAIN: "{{ inpx_web_cname }}.{{ lan_domain }}"
    labels:
      traefik.enable: "true"
      traefik.http.routers.liberama.rule: "Host(`{{ inpx_web_cname }}.{{ lan_domain }}`) && PathPrefix(`/read`)"
      traefik.http.routers.liberama.entrypoints: "websecure"
      traefik.http.routers.liberama.service: "liberama-svc"
      traefik.http.routers.liberama.tls: "true"
      traefik.http.routers.liberama.tls.certresolver: "step-ca"
      traefik.http.services.liberama-svc.loadbalancer.server.port: "44080"
