---
services:
  beszel-hub:
    image: "{{ beszel_image_name }}:{{ beszel_image_tag }}"
    restart: unless-stopped
    ports:
      - "{{ beszel_port }}:8090"
    volumes:
      - "{{ beszel_data_dir }}/data:/beszel_data"
    environment:
      APP_URL: "https://{{ beszel_hub_cname }}.{{ lan_domain }}"
      USER_EMAIL: "{{ beszel_admin_email }}"
      USER_PASSWORD: "{{ beszel_admin_password }}"
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8090/ || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    labels:
      traefik.enable: "true"
      traefik.http.routers.beszel.rule: "Host(`{{ beszel_hub_cname }}.{{ lan_domain }}`)"
      traefik.http.routers.beszel.entrypoints: "websecure"
      traefik.http.routers.beszel.tls: "true"
      traefik.http.routers.beszel.tls.certresolver: "step-ca"
      traefik.http.services.beszel.loadbalancer.server.port: "{{ beszel_port }}"
