---
services:
  vaultwarden:
    image: "{{ vaultwarden_image_name }}:{{ vaultwarden_image_tag }}"
    restart: unless-stopped
    volumes:
      - "{{ vaultwarden_data_dir }}:/data"
    environment:
      DOMAIN: "https://{{ vaultwarden_cname }}.{{ lan_domain }}"
      ADMIN_TOKEN: "{{ vaultwarden_admin_token }}"
      SIGNUPS_ALLOWED: "true"
      LOG_LEVEL: "warn"
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:80/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    labels:
      traefik.enable: "true"
      traefik.http.routers.vaultwarden.rule: "Host(`{{ vaultwarden_cname }}.{{ lan_domain }}`)"
      traefik.http.routers.vaultwarden.entrypoints: "websecure"
      traefik.http.routers.vaultwarden.tls: "true"
      traefik.http.routers.vaultwarden.tls.certresolver: "step-ca"
      traefik.http.services.vaultwarden.loadbalancer.server.port: "80"
