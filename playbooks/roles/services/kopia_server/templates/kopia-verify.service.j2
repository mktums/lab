[Unit]
Description=Kopia repository verification (daily 5% sample)
Requires=docker.socket
After=docker.socket

[Service]
Type=oneshot
ExecStart=/usr/bin/docker compose -f {{ kopia_opt_dir }}/docker-compose.yml exec kopia-server kopia snapshot verify --verify-files-percent=5 --file-parallelism=4 --parallel=4
