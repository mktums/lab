services:
  step-ca:
    image: smallstep/step-ca:latest
    container_name: step-ca
    restart: unless-stopped
    ports:
      - "{{ step_ca_port }}:9000"
    volumes:
      - /data/docker/step-ca:/home/step
      - /opt/step-ca/secrets/password:/run/secrets/password:ro
    environment:
      # Only evaluated on first run (before /home/step is populated)
      DOCKER_STEPCA_INIT_NAME: "{{ step_ca_name }}"
      DOCKER_STEPCA_INIT_DNS_NAMES: "localhost,step-ca.{{ lan_domain }},{{ inventory_hostname }}.{{ lan_domain }}"
      DOCKER_STEPCA_INIT_ACME: "true"
      DOCKER_STEPCA_INIT_PASSWORD_FILE: /run/secrets/password
