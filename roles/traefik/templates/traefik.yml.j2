global:
  checkNewVersion: false
  sendAnonymousUsage: false

log:
  level: INFO

api:
  dashboard: true
  insecure: false

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
  websecure:
    address: ":443"

providers:
  docker:
    exposedByDefault: false

certificatesResolvers:
  step-ca:
    acme:
      email: "{{ traefik_acme_email }}"
      storage: /acme/acme.json
      caServer: "https://step-ca.{{ lan_domain }}:{{ step_ca_port }}/acme/acme/directory"
      tlsChallenge: {}
